# scion ignore
.scion/agents
.scion/harness-configs
.scion/settings.yaml
.scion/grove-id
.scion/state.yaml
examples/*/.scion/agents/
examples/*/.scion/harness-configs/
examples/*/.scion/grove-id
examples/*/.scion/settings.yaml
examples/*/.scion/state.yaml
examples/*/.work/
examples/*/scripts/.test-output/

# local claude code settings
.claude/

# binaries
/build/
/.build/
/scion
scion-agent
extras/scion-chat-app/scion-chat-app

# secrets
TEST_GEMINI_KEY

# agent scratch space
.scratch/

# web frontend
web/node_modules/
web/dist/*
!web/dist/client
web/dist/client/*
!web/dist/client/.gitkeep
web/public/assets/
web/public/shoelace/

# docs site
docs-site/node_modules/
docs-site/dist/
docs-site/.astro/
docs-site/.env
docs-site/.env.production
web/.env
web/.env.local
web/.env.*.local
web/coverage/
*.log
npm-debug.log*

# IDE / OS (global)
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
